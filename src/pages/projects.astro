---
// src/pages/projects.astro
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.jsx';

// ─── ADD YOUR GITHUB LINKS HERE ───────────────────────────────────────────────
// Set `github: "https://github.com/thatdudegrantt/repo-name"` on any project.
// Leave `github` out (or set to null) and the card behaves exactly as before.
// Repos can be public OR private — visitors just won't see code if private.
// ──────────────────────────────────────────────────────────────────────────────
const projects = [
  {
    title: "Yellow Jacket Roller Derby Practice Planner",
    tech: ["TypeScript", "Next.js", "Vercel"],
    date: "Present",
    description: [
      "Developed a fullstack app with a database storing user accounts, practice plan creation, and export functionality to share with the active userbase.",
      "Collaborated with executive board members on designing the user interface & user stories.",
      "Deployed via Vercel & secured with SSL encryption.",
    ],
    // github: "https://github.com/thatdudegrantt/roller-derby-planner",
  },
  {
    title: "Georgia Tech Robojackets Team & Inventory Management",
    tech: ["Next.js", "TypeScript", "PocketBase", "Mantine UI"],
    date: "Aug 2025 – Present",
    description: [
      "Developed a fullstack app with a real-time database storing user accounts, practice plan creation, and export capabilities.",
      "Implemented a real-time data verification system to validate and ensure accuracy of user information.",
      "Collaborated with a co-developer and club leaders to launch an online registration system adopted by 100% of active users.",
      "Spearheaded frontend UI changes that increased retention among club members.",
      "Restructured code as generics, paginated displayed data, and maintained real-time updates with solid OOP practices.",
    ],
    // github: "https://github.com/thatdudegrantt/robojackets-management",
  },
  {
    title: "Plankton Computer Vision Project",
    tech: ["Python", "Jupyter Notebooks", "Computer Vision"],
    date: "Jan 2025 – Present",
    description: [
      "Scrum-like role designing semester-long roadmap for an 8-person team.",
      "Redesigned neural network (Inception V4) for plankton species identification.",
      "Implemented preprocessing pipeline that improved model accuracy by 45%.",
    ],
    // github: "https://github.com/thatdudegrantt/plankton-cv",
  },
  {
    title: "Personal Website (this site!)",
    tech: ["Astro", "Tailwind CSS", "Framer Motion", "Cloudflare Pages"],
    date: "Aug 2025",
    description: [
      "Portfolio website presenting my projects and both my behavioral & technical skills.",
      "Features a responsive design & interactive elements with smooth animations.",
      "Migrated from Next.js/Vercel to Astro/Cloudflare Pages.",
    ],
    github: "https://github.com/thatdudegrantt/personal-site",
  },
  {
    title: "2D GameBoy Advance System & Custom Frogger Game",
    tech: ["C", "Docker", "Game Development", "Low-level Programming"],
    date: "Mar 2025",
    description: [
      "Implemented GBA hardware-level features including DMA and memory-mapped I/O.",
      "Developed a Frogger clone with custom collision detection, assets, and state-machine game logic.",
      "Optimized for strict GBA hardware constraints.",
    ],
    // github: "https://github.com/thatdudegrantt/gba-frogger",
  },
  {
    title: "Audioscape Journey (Spotify Wrapped)",
    tech: ["Python", "Django", "JavaScript"],
    date: "Oct 2024 – Dec 2024",
    description: [
      "Class-leading project using Agile methodologies for CS 2340.",
      "Dynamic website leveraging the Spotify API for music data visualization.",
      "Integrated Google's Gemini LLM, Spotify/Apple Music APIs, and Reddit's API for game logic.",
    ],
    // github: "https://github.com/thatdudegrantt/audioscape",
  },
  {
    title: "Atlanta Food Finder",
    tech: ["Python", "Django", "JavaScript"],
    date: "Aug 2024 – Oct 2024",
    description: [
      "Map-based restaurant search application.",
      "Implemented backend logic and review system.",
      "User-friendly UI design with intuitive navigation.",
    ],
    // github: "https://github.com/thatdudegrantt/atlanta-food-finder",
  },
  {
    title: "2D Platform Video Game",
    tech: ["C#", "Unity"],
    date: "Jun 2024 – Aug 2024",
    description: [
      "Designed gameplay mechanics and physics.",
      "Created custom assets and animations.",
      "Focus on maintainable, scalable code architecture.",
    ],
    // github: "https://github.com/thatdudegrantt/2d-platformer",
  },
  {
    title: "Secure Password Generator",
    tech: ["Python"],
    date: "Spring 2023",
    description: [
      "Random password generation with security-focused features.",
      "Customizable length and character sets.",
      "Command-line interface (my first CS project — a solid foundation!)",
    ],
    // github: "https://github.com/thatdudegrantt/password-generator",
  },
];
---

<Layout title="Projects — Grant Polazzo">
  <div class="min-h-screen bg-base-200 p-4 md:p-8">
    <div class="max-w-6xl mx-auto">
      <h1 class="text-3xl md:text-4xl font-bold text-base-content mb-2">My Projects</h1>
      <p class="text-base text-base-content opacity-70 mb-8">
        Sorted by date. Click any card with a
        <svg class="inline w-3.5 h-3.5 mx-0.5 mb-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
        icon to view its GitHub repo.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 items-start">
        {projects.map((project) => (
          <ProjectCard
            client:load
            title={project.title}
            tech={project.tech}
            date={project.date}
            description={project.description}
            github={project.github}
          />
        ))}
      </div>
    </div>
  </div>
</Layout>
